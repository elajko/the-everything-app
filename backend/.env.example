# Local dev: SQLite file, no setup required.
DATABASE_URL="file:./dev.db"

# Swap to something like this when you deploy to Postgres:
# DATABASE_URL="postgresql://user:password@host:5432/everything_app"

PORT=4000

# There's no real auth yet — every request acts as this seeded user.
# Replace with real session/JWT auth later.
CURRENT_USER_HANDLE="you"
