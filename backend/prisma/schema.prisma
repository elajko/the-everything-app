// Prisma schema for The Everything App
// Local dev uses SQLite (file-based, zero setup). Swap `provider` to
// "postgresql" and set DATABASE_URL to a Postgres connection string
// when you're ready to deploy — the schema itself doesn't need to change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Prisma enums require a connector SQLite doesn't support, so this is
// a plain String, validated against VALID_SECTIONS in routes/posts.js.
model User {
  id        String   @id @default(cuid())
  handle    String   @unique
  name      String
  // null means no picture set — the frontend renders a generic default
  // silhouette in that case rather than expecting every user to have one.
  avatarUrl String?
  // profile customization — data structures only for now, no edit UI until
  // there's real auth to gate it. bio is the "about me" paragraph. bannerUrl
  // is the wide header image shown above the hero section on the profile
  // page; null just means no banner renders (not every seeded user has one).
  bio       String?
  bannerUrl String?
  // shows a "Verified news provider" subheader on the profile page — set by
  // whatever process approves a News tab posting application (not built
  // yet; see the composer's gate button on the News tab). Not user-editable.
  verifiedNewsProvider Boolean @default(false)
  createdAt DateTime @default(now())

  posts         Post[]
  likes         Like[]
  notifications Notification[] @relation("NotificationRecipient")
  triggeredNotifications Notification[] @relation("NotificationActor")

  channelVideos Video[]       @relation("VideoChannel")
  videoLikes    VideoLike[]
  links         ProfileLink[]

  sentMessages     Message[] @relation("MessagesSent")
  receivedMessages Message[] @relation("MessagesReceived")
}

// External links on a profile (Patreon, Twitch, YouTube, personal site,
// etc.), shown as a card grid. `platform` picks a recognizable icon on the
// frontend (see PLATFORM_ICONS) — unset/unrecognized falls back to a
// generic link icon. `label` is the display name (e.g. "Twitch"); optional
// `description` is the small line underneath (e.g. "Watch my livestreams!").
model ProfileLink {
  id          String  @id @default(cuid())
  userId      String
  platform    String?
  label       String
  url         String
  description String?
  sortOrder   Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique

  posts  PostTag[]
  videos VideoTag[]
}

// Explicit join table so we can enforce "1-3 tags per post" in application code
// and keep the relation queryable in both directions.
model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

// Social/News content. Streaming videos are NOT posts — see Video below —
// so `section` is only ever "social" or "news" (VALID_SECTIONS in
// routes/posts.js). A post may still attach an image or a video as plain
// media (XOR, no title), but that's cosmetically identical to an image post;
// it never gets the Streaming tab's YouTube-style treatment.
model Post {
  id        String   @id @default(cuid())
  authorId  String
  section   String
  body      String   @default("")
  imageUrl  String?
  videoUrl  String?
  createdAt DateTime @default(now())

  // Self-relation for reposts of another post: a repost is its own Post row
  // that points at the post it embeds. The original post is never modified.
  repostOfId String?
  repostOf   Post?    @relation("Reposts", fields: [repostOfId], references: [id])
  repostedBy Post[]   @relation("Reposts")

  // A repost can instead target a streaming Video — mutually exclusive with
  // repostOfId (a repost has exactly one original, and that original is
  // either a Post or a Video, never both). Rendered as a distinct compact
  // "watch streaming video" card, not a normal post embed.
  repostOfVideoId String?
  repostOfVideo   Video?  @relation("VideoReposts", fields: [repostOfVideoId], references: [id])

  // A comment IS a post — same author/likes/reposts/replies machinery as
  // any other post, just one with a parent set (via POST /:id/comment,
  // which skips the normal tag requirement). Distinct from repostOfId: a
  // repost re-shares content under a new post, a reply responds to it —
  // never both set on the same post. Deleting the parent cascades to its
  // replies, same as any other owned child row.
  parentId String?
  parent   Post?   @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Post[]  @relation("Replies")

  // A comment can instead target a streaming Video — mutually exclusive
  // with parentId, mirroring repostOfVideoId's relationship to repostOfId.
  parentVideoId String?
  parentVideo   Video?  @relation("VideoReplies", fields: [parentVideoId], references: [id], onDelete: Cascade)

  author User      @relation(fields: [authorId], references: [id])
  tags   PostTag[]
  likes  Like[]
  notifications Notification[]

  @@index([section, createdAt])
  @@index([parentId])
  @@index([parentVideoId])
}

model Like {
  id     String @id @default(cuid())
  userId String
  postId String

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId]) // one like per user per post
}

// Streaming content lives here, entirely separate from Post — only Videos
// appear in the Streaming tab, only Posts appear in Social/News. A Video
// can be reposted (see Post.repostOfVideoId), which notifies nobody today
// (Notification is Post-shaped only — out of scope for this split) but does
// embed a compact preview card wherever the resulting post is shown.
model Video {
  id           String   @id @default(cuid())
  channelId    String
  videoUrl     String
  videoTitle   String
  thumbnailUrl String?
  description  String   @default("")
  createdAt    DateTime @default(now())

  channel User        @relation("VideoChannel", fields: [channelId], references: [id])
  tags    VideoTag[]
  likes   VideoLike[]
  repostedBy Post[]   @relation("VideoReposts")
  replies    Post[]   @relation("VideoReplies")

  @@index([createdAt])
}

model VideoTag {
  videoId String
  tagId   String

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([videoId, tagId])
}

model VideoLike {
  id      String @id @default(cuid())
  userId  String
  videoId String

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

// Only "repost" is ever written (see routes/posts.js); plain String for the
// same SQLite-enum-support reason as Post.section above.
model Notification {
  id        String   @id @default(cuid())
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // who receives the notification (the original post's author)
  recipientId String
  recipient   User @relation("NotificationRecipient", fields: [recipientId], references: [id])

  // who caused it (the person who reposted)
  actorId String
  actor   User @relation("NotificationActor", fields: [actorId], references: [id])

  // the post that was reposted
  postId String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([recipientId, read])
}

// Private 1:1 direct messages. There's no separate Conversation row — a
// "conversation" is just every Message between two users, derived on read
// (see routes/messages.js) rather than modeled, since this is always a
// simple two-person thread (no group DMs). `read` only matters from the
// recipient's side; opening a thread marks the other person's messages as
// read as a side effect.
model Message {
  id          String   @id @default(cuid())
  body        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  senderId    String
  sender      User @relation("MessagesSent", fields: [senderId], references: [id])

  recipientId String
  recipient   User @relation("MessagesReceived", fields: [recipientId], references: [id])

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, read])
}
